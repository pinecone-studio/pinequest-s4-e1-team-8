{
  "name": "client",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "CLOUDFLARE_LOAD_DEV_VARS_FROM_DOT_ENV=true bun --bun next dev --webpack",
    "build": "NODE_OPTIONS='--max-old-space-size=8192' next build --webpack",
    "start": "bun --bun next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "build:cf": "NODE_OPTIONS='--max-old-space-size=8192' next build --webpack && node scripts/fix-standalone-deps.mjs",
    "preview": "bun run build:cf && opennextjs-cloudflare build --skipNextBuild && node scripts/patch-handler-middleware.mjs && opennextjs-cloudflare preview",
    "deploy": "node scripts/deploy-production.mjs",
    "deploy:prod": "node scripts/deploy-production.mjs",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@clerk/nextjs": "^7.4.3",
    "@clerk/ui": "^1.15.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hello-pangea/dnd": "^18.0.1",
    "@hookform/resolvers": "^5.4.0",
    "@opennextjs/cloudflare": "^1.19.11",
    "axios": "^1.15.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "googleapis": "^173.0.0",
    "livekit-client": "^2.19.1",
    "lucide-react": "^1.17.0",
    "next": "16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.78.0",
    "shadcn": "^4.10.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "esbuild": "0.24.2",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/bun": "latest",
    "@types/node": "^20",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4.3.0",
    "typescript": "^5",
    "wrangler": "^4.98.0"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
