# Local Worker secrets template. Copy this file to `.dev.vars` and fill real values.
#   cp .dev.vars.example .dev.vars
# `.dev.vars` is gitignored. NEVER commit real keys.
# Non-secret values (LIVEKIT_URL, R2_ACCOUNT_ID, etc.) already live in wrangler.jsonc "vars".

# --- Azure Speaker Recognition (voice identity / verify) ---
# Speech resource Key 1 and its region (e.g. southeastasia, eastus).
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
# Force the provider. "azure" = use Azure. "local" = offline fallback.
# Leave unset to auto-pick Azure when the two keys above are present.
VOICE_VERIFICATION_MODE=azure
# Local testing only: lets the voice routes work without a Clerk login. Never set in prod.
VOICE_DEV_BYPASS=true

# --- Chimege (Mongolian speech-to-text) ---
CHIMEGE_API_KEY=
# Optional override; defaults to https://api.chimege.com
# CHIMEGE_BASE_URL=

# --- LiveKit (meeting audio / rooms / egress) ---
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- Other secrets the Worker needs to boot ---
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
GITHUB_WEBHOOK_SECRET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
