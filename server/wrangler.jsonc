{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "server-preset",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-16",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "server-preset-db",
      "database_id": "8ba899c2-abcc-4392-a298-518b3c3dcce6",
      "migrations_dir": "drizzle",
    },
  ],
  "vars": {
    "LIVEKIT_URL": "wss://your-project.livekit.cloud",
    "LIVEKIT_API_KEY": "APIKPm9Sr87RShW",
    "LIVEKIT_API_SECRET": "your_secret_here",
  },
  "env": {
    "production": {
      "d1_databases": [
        {
          "binding": "DB",
          "database_name": "server-preset-db",
          "database_id": "8ba899c2-abcc-4392-a298-518b3c3dcce6",
          "migrations_dir": "drizzle",
        },
      ],
      "vars": {
        "LIVEKIT_URL": "wss://your-project.livekit.cloud",
        "LIVEKIT_API_KEY": "APIKPm9Sr87RShW",
        "LIVEKIT_API_SECRET": "your_secret_here",
      },
    },
  },
}
