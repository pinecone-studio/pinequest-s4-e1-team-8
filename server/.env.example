# =============================================================================
# Drizzle migrations only — drizzle.config.ts reads .env.local
# Copy these three keys to server/.env.local (or keep them here and symlink)
# =============================================================================

CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_DATABASE_ID=
CLOUDFLARE_D1_TOKEN=

# =============================================================================
# Worker runtime — Wrangler does NOT read this file.
# Put all keys below in server/.dev.vars (see .dev.vars.example)
# =============================================================================

# GitHub OAuth (GitHub → Settings → Developer settings → OAuth Apps)
# Callback URL must be: http://localhost:8788/integrations/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:8788/integrations/github/callback
CLIENT_APP_URL=http://localhost:3000

# LiveKit
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_EGRESS_WEBHOOK_URL=

# Chimege STT
CHIMEGE_API_KEY=
CHIMEGE_BASE_URL=https://api.chimege.com/

# Cloudflare R2 (recordings)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# AI
GEMINI_API_KEY=

# Optional
FRONTEND_URL=http://localhost:3000
GITHUB_WEBHOOK_SECRET=
GITHUB_TEST_TOKEN=
