{
  "name": "server-preset",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --port 8788",
    "deploy": "wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "generate": "drizzle-kit generate",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply server-preset-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply server-preset-db --remote",
    "db:seed:local": "wrangler d1 execute server-preset-db --local --file=./scripts/seed.sql",
    "db:setup:local": "bun run db:migrate:local && bun run db:seed:local"
  },
  "dependencies": {
    "@langchain/core": "^1.1.48",
    "@langchain/google-genai": "^2.1.31",
    "@langchain/langgraph": "^1.3.5",
    "dotenv": "^17.4.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.12",
    "livekit-server-sdk": "^2.15.4",
    "nanoid": "^5.1.11",
    "svix": "^1.95.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260411.1",
    "drizzle-kit": "^0.31.10",
    "wrangler": "^4.4.0",
    "@types/bun": "latest"
  },
  "module": "src/index.ts",
  "private": true,
  "peerDependencies": {
    "typescript": "^5"
  }
}
